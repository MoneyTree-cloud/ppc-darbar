###############################################
# BLOCK WEBSITE COPIERS (HTTrack, Wget, etc.)
###############################################
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} ^.*(HTTrack|httrack|WebCopier|Wget|wget|Teleport|Website|WebZIP|SiteSnagger|SiteSucker|Offline|EmailSiphon|ChinaClaw|Nutch|WebStripper|WebCopy).* [NC]
RewriteRule ^.* - [F,L]
</IfModule>

###############################################
# BLOCK ACCESS TO SENSITIVE FILES
###############################################
<FilesMatch "^\.env|\.log$|^env\.php$|^connection\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

###############################################
# DISABLE DIRECTORY LISTING
###############################################
Options -Indexes

###############################################
# DEFAULT DOCUMENT
###############################################
DirectoryIndex index.php index.html

###############################################
# BLOCK RAPID SCRAPING (RATE LIMIT)
###############################################
<IfModule mod_evasive20.c>
    DOSHashTableSize    3097
    DOSPageCount        5
    DOSSiteCount        50
    DOSPageInterval     1
    DOSSiteInterval     1
    DOSBlockingPeriod   60
</IfModule>
