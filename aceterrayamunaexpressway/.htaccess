###############################################
# BLOCK SENSITIVE FILES (.env, .log, env.php)
###############################################
<FilesMatch "^\.env|\.log$|^env\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

###############################################
# BLOCK WEBSITE COPIERS (HTTrack, Wget, etc.)
###############################################
<IfModule mod_rewrite.c>
RewriteEngine On

# Block common offline downloaders
RewriteCond %{HTTP_USER_AGENT} ^.*(HTTrack|httrack|WebCopier|Wget|wget|Teleport|Website|WebZIP|SiteSnagger|SiteSucker|Offline|EmailSiphon|ChinaClaw|Nutch|WebStripper|WebCopy).* [NC]
RewriteRule ^.* - [F,L]

# Clean URLs: remove .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>

###############################################
# DISABLE DIRECTORY LISTING
###############################################
Options -Indexes

###############################################
# BLOCK RAPID SCRAPING (RATE LIMIT)
###############################################
<IfModule mod_evasive20.c>
    DOSHashTableSize    3097
    DOSPageCount        5
    DOSSiteCount        50
    DOSPageInterval     1
    DOSSiteInterval     1
    DOSBlockingPeriod   60
</IfModule>
