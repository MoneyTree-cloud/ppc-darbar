<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} ^.*(HTTrack|httrack|WebCopier|Wget|wget|Teleport|WebZIP|SiteSnagger|SiteSucker|Offline|EmailSiphon|ChinaClaw|Nutch|WebStripper|WebCopy).* [NC]
RewriteRule ^.* - [F,L]
</IfModule>

<FilesMatch "^\.env|\.log$|^env\.php$|^connection\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

Options -Indexes
